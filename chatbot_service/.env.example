# ──────────────────────────────────────────────────────────
# InternHub Backend Environment Variables (EXAMPLE)
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────

# ── Groq LLM Configuration ─────────────────────────────────
# Get API key from: https://console.groq.com
# Copy your API key here (keep it secret!)
GROQ_API_KEY=gsk_your_actual_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── PostgreSQL Database Configuration ──────────────────────
# Docker service name or localhost
DB_HOST=localhost
DB_PORT=5433
DB_NAME=intern_management
DB_USER=postgres
# ⚠️ CHANGE THIS IN PRODUCTION
DB_PASSWORD=vidhikasttl

# ── ChromaDB Vector Store Configuration ────────────────────
# Local path where Vanna stores embeddings/training data
CHROMA_PATH=./chroma_db

# ── JWT Authentication Configuration ───────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-randomly-generated-secret-key-here
JWT_ALGORITHM=HS256

# ── CORS Configuration ─────────────────────────────────────
# Comma-separated list of allowed origins
# For local dev: http://localhost:3000
# For prod: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server Configuration ───────────────────────────────────
# FastAPI server port
PORT=8001
